APP_ENV=prod
API_BASE_URL=https://app.rossicompany.com.br
DB_URL=jdbc:postgresql://postgres:5432/despesasdb
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
APP_SECURITY_TOKEN_SECRET=CHANGE_ME
APP_OPERATIONAL_EMAIL_INGESTION_TOKEN=CHANGE_ME
APP_FRONTEND_WEB_DIST=file:/app/frontend-web/
BACKEND_IMAGE=ghcr.io/example/despesas-backend:manual-preflight
APP_PUBLIC_HOST=app.rossicompany.com.br
N8N_PUBLIC_HOST=n8n.rossicompany.com.br
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
APP_SHOW_SQL=false
FINANCIAL_ASSISTANT_AI_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_LOG_REQUESTS=false
DEEPSEEK_LOG_RESPONSES=false
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MAX_COMPLETION_TOKENS=220
DEEPSEEK_TIMEOUT_SECONDS=20
DEEPSEEK_MAX_RETRIES=1
